---
import Layout from '../layouts/Layout.astro';
import Header from '../components/header.astro';
import Cards from '../components/cards.astro';
import Footer from '../components/footer.astro';

import "../styles/global.css";
import "../styles/index.css";
import "../styles/aboutme.css"
import "../styles/projects.css"

import github from '../assets/github-sign.png';
import linkedin from '../assets/linkedin.png'
import cv from '../assets/cv.png'
// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<Header />
	<main>
		<section class="welcome">
			<div class="top-content">
				<h1>FRANCISCO GARCIA</h1>
				<span>Hi! Nice to meet you. I'm tecnicial computer and engennier student</span>
			</div>
			<div class="bottom-content">
				<div class="card-welcome-section" id="Linkedin">
					<img src={linkedin.src} alt="LinkedIn">
					<a href="">Linkedin</a>
				</div>
				<div class="card-welcome-section" id="CV">
					<img src={cv.src} alt="CV">
					<a href="">Curriculum Vitae</a>
				</div>
				<div class="card-welcome-section" id="github">
					<img src={github.src} alt="GitHub">
					<a href="">Github</a>
				</div>
			</div>
		</section>
	</main>
	
	<section class="about">
		<div class="about-grid">
			
			<div class="about-col-left">
				<span class="about-tag">About me</span>
				<p>
					I'm a Computer Technician graduated with honors, currently studying 
					Computer Engineering at Universidad de Belgrano. I specialize in 
					information systems development, software architecture and project management.
				</p>
				<div class="about-card-placeholder">
					<!-- Tu contenido futuro -->
				</div>
			</div>
			
			<div class="about-col-right">
				<p>
					Over four years of intensive training shaped my technical foundation, 
					working with technologies like C#, .NET, SQL, JavaScript and Git. 
					I enjoy designing complete system architectures and leading development 
					teams through agile methodologies.
				</p>
			</div>
		</div>
	</section>
	
	<section class="projects">
		<div class="conteiner-projects">
			<div class="projects-text">
				<h1>Highligth Projects</h1>
				<span>Click on cards to view details</span>
			</div>
			<div class="carousel carousel--scroll-buttons carousel--scroll-markers">
				<div class="carousel__slide" data-label="Slide 1"><Cards id="aurora" /></div>
				<div class="carousel__slide" data-label="Slide 2"><Cards id="casystem" /></div>
				<div class="carousel__slide" data-label="Slide 3"><Cards id="games" /></div>
			</div>
		</div>
	</section>
	<Footer />
</Layout>


