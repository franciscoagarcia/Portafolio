---
const { id } = Astro.props;
---

<div class="container-cards" id={id}>
    <a href={`/projects/${id}`}>
        <figure></figure>
    </a>
</div>

<style>
    .container-cards {
        width: 400px;
        height: 400px;
        border-radius: 16px;
        overflow: hidden;
        background: transparent;
    }

    a {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        border-radius: 16px;
        overflow: hidden;
    }

    figure {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        margin: 0;
    }

    figure img {
        max-width: 60%;
        max-height: 60%;
        object-fit: contain;
        display: block;
    }

    #aurora {
        background-color: #081524;
        background-image: url('/images/Aurora.png');
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
    }

    #casystem {
        background-image: url('/images/CASystem.png');
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
    }

    #games {
        background-image: url('/images/5MinutesGames.png');
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
    }
</style>