---
import flecha from '../assets/flecha.png';
import aurora from '../assets/isotipo.png';
import home from '../assets/home.png';
import aboutme from '../assets/aboutme.png';
import project from '../assets/projects.png';
import contact from '../assets/contacto.png';
---

<header class="encabezado">
    <div class="container-encabezado">
        <div class="figures-row">
            <figure><img src={aurora.src} alt=""></figure>
            <figure><img src={flecha.src} id="flechaid" alt=""></figure>
        </div>

        <div class="container-links">
            <div class="card-link">
                <img src={home.src} alt="">
                <a href="">Home</a>
            </div>
            <div class="card-link">
                <img src={aboutme.src} alt="">
                <a href="">About Me</a>
            </div>
            <div class="card-link">
                <img src={project.src} alt="">
                <a href="">Projects</a>
            </div>
            <div class="card-link">
                <img src={contact.src} alt="">
                <a href="">Contact</a>
            </div>
        </div>
    </div>

</header>

<style>
    .encabezado {
        position: fixed;
        top: 0;
        width: 100%;
        height: 70px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 10px;
        z-index: 100; 
    }

    .container-encabezado {
        width: 200px;
        height: 50px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        background-color: #ffffff;
        padding: 8px 10px 0 10px;
        border-radius: 16px;
        border: 2px solid #343434;
        overflow: hidden;
        transition: width 0.3s ease-in-out, height 0.3s ease-in-out;
    }


    .container-encabezado > div:first-of-type,
    .figures-row {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        gap: 8px;
        width: 100%;
    }

    .container-encabezado figure {
        position: relative;
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        width: 30px;
        height: 30px;
        border-radius: 16px;
    }

    .container-encabezado figure img {
        border-radius: 50%;
        object-fit: contain;
    }

    .container-encabezado:hover {
        width: 350px;
        height: 240px;
        border-radius: 16px;
        border: 2px solid #343434;
    }

    .container-encabezado:hover #flechaid {
        transition: all 0.5s ease-in-out;
        rotate: 90deg;
    }

    .container-links {
        display: flex;
        flex-direction: column;
        gap: 4px;
        width: 100%;
        margin-top: 12px;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease 0s;
    }

    .container-encabezado:hover .container-links {
        opacity: 1;
        pointer-events: all;
        transition: opacity 0.2s ease 0.25s;
    }

    .card-link {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 10px;
        text-decoration: none;
        transition: background 0.15s ease;
        cursor: pointer;
    }

    .card-link:hover {
        background-color: #f5f5f5;
    }

    /* Isotipo del link */
    .card-link img {
        width: 22px;
        height: 22px;
        object-fit: contain;
        flex-shrink: 0;
    }

    /* Texto del link */
    .card-link a {
        text-decoration: none;
        color: #111;
        font-size: 13px;
        font-weight: 500;
        white-space: nowrap;
    }
</style>